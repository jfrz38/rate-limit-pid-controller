{
  "name": "@jfrz38/rate-limit-pid-controller",
  "version": "0.0.1",
  "description": "Rate Limiter built for Express usage based on Uber's Cinnamon",
  "main": "dist/src/index.js",
  "module": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "build:clean": "npm run clean && npm run build",
    "start": "ts-node src/index.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:leak": "jest --detectOpenHandles",
    "local": "ts-node src/index.local.ts",
    "lint:src": "eslint src",
    "lint:fix": "eslint --fix"

  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jfrz38/rate-limit-pid-controller.git"
  },
  "keywords": [
    "rate-limiter",
    "typescript",
    "cinnamon",
    "uber",
    "limiter"
  ],
  "author": "José F. Ruiz <jrz899@inlumine.ual.es>",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/jfrz38/rate-limit-pid-controller/issues"
  },
  "homepage": "https://github.com/jfrz38/rate-limit-pid-controller#readme",
  "devDependencies": {
    "@types/jest": "30.0.0",
    "@types/node": "24.3.1",
    "@typescript-eslint/eslint-plugin": "8.53.0",
    "@typescript-eslint/parser": "8.53.0",
    "typescript-eslint": "8.52.0",
    "eslint": "9.39.2",
    "jest": "30.1.3",
    "ts-jest": "29.4.2",
    "ts-node": "10.9.2",
    "typescript": "5.9.2"
  },
  "dependencies": {
    "heap-js": "2.7.1",
    "p-queue": "8.1.1",
    "pino": "10.0.0"
  }
}
