{
  "name": "@jfrz38/express-pid-controller",
  "author": "José F. Ruiz <jrz899@inlumine.ual.es>",
  "license": "MIT",
  "version": "0.0.1",
  "description": "Express adapter for the PID rate limiter core",
  "main": "./dist/src/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "dependencies": {
    "@jfrz38/pid-controller-core": "workspace:*"
  },
  "peerDependencies": {
    "express": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jfrz38/rate-limit-pid-controller.git",
    "directory": "code/adapters/express"
  },
  "scripts": {
    "build": "tsc",
    "build:clean": "npm run clean && npm run build",
    "start": "ts-node src/index.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:coverage": "vitest --coverage",
    "test:leak": "vitest --detectOpenHandles",
    "lint": "eslint src",
    "lint:src": "eslint src",
    "lint:fix": "eslint \"{src,tests}/**/*.ts\" --fix"
  },
  "type": "commonjs",
  "keywords": [],
  "packageManager": "pnpm@10.12.3",
  "devDependencies": {
    "@types/express": "4.17.0"
  }
}
